{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "noImplicitAny": true,
    "noUncheckedIndexedAccess": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "declaration": false,
    "sourceMap": false,
    "baseUrl": ".",
    "paths": {
      "@veo-core/*": ["skills/_shared/veo-core/*"]
    }
  },
  "include": [
    "skills/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "coverage"
  ]
}
